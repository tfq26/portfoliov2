---
import { getEntry, render } from 'astro:content';

const aboutEntry = await getEntry('about', 'index');
if (!aboutEntry) {
  throw new Error('About entry not found');
}
const { Content } = await render(aboutEntry);
---
<section id="about" class="w-full py-16 md:py-24 px-6 reveal">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-bold text-center mb-12 text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-indigo-600 dark:from-blue-400 dark:to-indigo-500">
      {aboutEntry.data.title}
    </h2>
    <div class="bg-white dark:bg-slate-800/50 rounded-2xl shadow-md border border-slate-200 dark:border-slate-700 p-8 md:p-10">
      <div class="grid md:grid-cols-5 gap-10 items-center">
        <div class="md:col-span-3 about-content">
          <Content />
          <div class="mt-8">
            <a
              href="/Software Development Resume 2026.pdf"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center text-lg font-semibold text-blue-600 hover:text-blue-700 dark:text-blue-400 dark:hover:text-blue-300 group"
            >
              View My Resume
              <svg class="ml-2 w-5 h-5 transition-transform group-hover:translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
            </a>
          </div>
        </div>
        <div class="md:col-span-2">
          <div class="bg-slate-100/70 dark:bg-slate-800 p-6 rounded-xl">
            <h4 class="text-xl font-bold mb-4 text-center text-slate-800 dark:text-white">When I'm not coding...</h4>
            <ul class="space-y-4">
              <li class="flex items-center gap-4">
                <div class="bg-blue-500/10 p-2 rounded-full text-blue-500">
                  <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 012-2h10a2 2 0 012 2v10a2 2 0 01-2 2H7a2 2 0 01-2-2V5zM7 8h10M7 12h10M7 16h10"></path></svg>
                </div>
                <span class="font-medium text-slate-700 dark:text-slate-300">Playing video games</span>
              </li>
              <li class="flex items-center gap-4">
                <div class="bg-blue-500/10 p-2 rounded-full text-xl text-center w-10">🎾</div>
                <span class="font-medium text-slate-700 dark:text-slate-300">Pickleball & Tennis</span>
              </li>
              <li class="flex items-center gap-4">
                <div class="bg-blue-500/10 p-2 rounded-full text-xl text-center w-10">🍳</div>
                <span class="font-medium text-slate-700 dark:text-slate-300">Cooking new recipes</span>
              </li>
            </ul>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  // Simple Intersection Observer for reveal on scroll
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('active');
      }
    });
  }, { threshold: 0.1 });

  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));
</script>

<style>
  @reference "tailwindcss";

  .reveal {
    opacity: 0;
    transform: translateY(30px);
    transition: all 0.8s ease-out;
  }
  .reveal.active {
    opacity: 1;
    transform: translateY(0);
  }

  .about-content :global(p) {
    @apply text-lg text-slate-600 dark:text-slate-300 mb-6 leading-relaxed;
  }
  
  .about-content :global(p:last-child) {
    @apply mb-0;
  }
</style>
