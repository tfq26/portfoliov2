---
import { getCollection } from 'astro:content';

const experience = await getCollection('experience');
const sortedExperience = experience.sort((a, b) => a.data.order - b.data.order);
---
<section id="experience" class="w-full py-16 md:py-24 px-6 reveal">
  <div class="max-w-7xl mx-auto">
    <h2 class="text-4xl md:text-5xl font-bold text-center mb-12 text-transparent bg-clip-text bg-gradient-to-r from-blue-500 to-indigo-600 dark:from-blue-400 dark:to-indigo-500">
      Professional Journey
    </h2>
    <div class="relative max-w-4xl mx-auto pl-8 border-l-2 border-slate-200 dark:border-slate-700">
      {sortedExperience.map((exp, index) => (
        <div class="relative mb-12 last:mb-0 reveal-item" style={`transition-delay: ${index * 100}ms`}>
          {/* The dot on the timeline */}
          <div class="absolute -left-[2.05rem] top-1 w-4 h-4 bg-blue-500 rounded-full border-4 border-white dark:border-zinc-900" />
          
          <div class="flex flex-col sm:flex-row sm:items-center sm:justify-between mb-2">
            <h3 class="text-xl font-bold text-slate-900 dark:text-white">{exp.data.role}</h3>
            <p class="text-sm font-medium text-slate-500 dark:text-slate-400 mt-1 sm:mt-0">{exp.data.period}</p>
          </div>

          <p class="text-md font-semibold text-blue-600 dark:text-blue-400 mb-4">
            {exp.data.company} &bull; {exp.data.location}
          </p>

          <p class="text-slate-600 dark:text-slate-400 mb-4">
            {exp.data.description}
          </p>
          
          <ul class="list-disc list-inside space-y-2 text-slate-600 dark:text-slate-400 mb-6">
            {exp.data.achievements.map((achievement) => (
              <li>{achievement}</li>
            ))}
          </ul>
          
          <div class="flex flex-wrap gap-2">
            {exp.data.technologies.map((tech) => (
              <span class="rounded-full bg-blue-100 px-3 py-1 text-xs font-semibold text-blue-800 dark:bg-blue-500/10 dark:text-blue-300">
                {tech}
              </span>
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .reveal-item {
    opacity: 0;
    transform: translateX(-20px);
    transition: all 0.6s ease-out;
  }
  .reveal.active .reveal-item {
    opacity: 1;
    transform: translateX(0);
  }
</style>
