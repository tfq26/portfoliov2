---
import { Image } from 'astro:assets';
import profileImage from '../assets/Taufeeq1.webp';
import bgImage from '../assets/Taufeeq3.jpg';
---
<section id="home" class="min-h-screen flex flex-col justify-end items-center text-center p-6 relative bg-transparent overflow-hidden pb-8 md:pb-16">
  <!-- Background Image with Overlay -->
  <div class="absolute inset-0 -z-20 overflow-hidden">
    <Image 
      src={bgImage} 
      alt="" 
      class="w-full h-full object-cover scale-105"
      loading="eager"
    />
  </div>
  
  <!-- Gradient Overlay for Text Readability (Bottom Up) -->
  <div class="absolute inset-x-0 bottom-0 h-[70vh] -z-10 bg-gradient-to-t from-white via-white/80 to-transparent dark:from-zinc-900 dark:via-zinc-900/80 dark:to-transparent"></div>

  <div class="reveal-nested z-10">
    <h1 class="text-4xl md:text-6xl font-bold mb-4 text-slate-900 dark:text-white drop-shadow-sm">
      Hi, I'm <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-600 dark:from-blue-400 dark:to-indigo-400">Taufeeq Ali</span>
    </h1>
    <p class="text-lg md:text-xl text-slate-700 dark:text-slate-300 max-w-2xl mx-auto font-medium drop-shadow-sm">
      Full Stack Developer & Cloud Enthusiast crafting modern, scalable, and user-friendly web applications.
    </p>

    <!-- Social Links -->
    <div class="flex justify-center space-x-4 mt-8">
      <a href="https://github.com/tfq26" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="GitHub">
        <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.011-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.43.372.823 1.102.823 2.222 0 1.606-.015 2.896-.015 3.286 0 .322.218.694.825.576C20.565 21.795 24 17.298 24 12c0-6.627-5.373-12-12-12z"/></svg>
      </a>
      <a href="https://linkedin.com/in/taufeeq-ali" target="_blank" rel="noopener noreferrer" class="social-link" aria-label="LinkedIn">
        <svg class="w-6 h-6 text-blue-600" fill="currentColor" viewBox="0 0 24 24"><path d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"/></svg>
      </a>
      <a href="/Software Development Resume 2026.pdf" download="Taufeeq_Ali_Resume" class="social-link" aria-label="Download Resume">
        <svg class="w-6 h-6 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
      </a>
    </div>
  </div>
</section>

<style>
  @reference "tailwindcss";

  .social-link {
    @apply bg-white/70 dark:bg-slate-800/50 backdrop-blur-sm p-3 rounded-full shadow-lg hover:bg-blue-100 dark:hover:bg-slate-700 transition-all duration-300 hover:scale-110 active:scale-90;
  }
</style>
